---
interface Props {
  images: string[];
  alt?: string;
  orientation?: "horizontal" | "vertical";
}
const {
  images,
  alt = "Capture du projet",
  orientation = "horizontal",
} = Astro.props;

const isVertical = orientation === "vertical";
---

<div class={`carousel-wrap ${isVertical ? "is-vertical" : "is-horizontal"}`}>
  <div class="carousel-container">
    <div class="carousel-track" id="track">
      {
        images.map((src, i) => (
          <div class="carousel-slide">
            <img
              src={src}
              alt={`${alt} ${i + 1}`}
              loading={i === 0 ? "eager" : "lazy"}
            />
          </div>
        ))
      }
    </div>
    <button class="btn btn-prev" id="prev" aria-label="Image précédente"
      >&#8249;</button
    >
    <button class="btn btn-next" id="next" aria-label="Image suivante"
      >&#8250;</button
    >
    <span class="counter" id="counter">1 / {images.length}</span>
  </div>

  <div class="dots">
    {
      images.map((_, i) => (
        <button
          class:list={["dot", { active: i === 0 }]}
          data-index={i}
          aria-label={`Aller à l'image ${i + 1}`}
        />
      ))
    }
  </div>

  <div class="thumbnails">
    {
      images.map((src, i) => (
        <button class:list={["thumb", { active: i === 0 }]} data-index={i}>
          <img src={src} alt={`Miniature ${i + 1}`} loading="lazy" />
        </button>
      ))
    }
  </div>
</div>

<style>
  /* ── Wrapper ── */
  .carousel-wrap {
    display: flex;
    flex-direction: column;
  }

  /* ── Container ── */
  .carousel-container {
    position: relative;
    overflow: hidden;
    border-radius: 12px;
    background: #f0f0f0;
  }

  /* Horizontal : ratio paysage 16/9 */
  .is-horizontal .carousel-container {
    width: 100%;
    aspect-ratio: 16 / 9;
  }

  /* Vertical : ratio portrait 9/16, centré, largeur fixe */
  .is-vertical .carousel-container {
    width: 560px;
    aspect-ratio: 9 / 16;
    margin: 0 auto;
    margin-bottom: 20px;
  }

  /* ── Track : toujours scroll horizontal ── */
  .carousel-track {
    display: flex;
    flex-direction: row;
    height: 100%;
    transition: transform 0.4s ease;
  }

  /* ── Slides ── */
  .carousel-slide {
    min-width: 100%;
    height: 100%;
    flex-shrink: 0;
  }
  .carousel-slide img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    background: #111;
  }

  /* ── Boutons gauche / droite ── */
  .btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: white;
    border: 1px solid #ddd;
    border-radius: 50%;
    width: 36px;
    height: 36px;
    cursor: pointer;
    font-size: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
    z-index: 2;
  }
  .btn:hover {
    background: #f5f5f5;
  }
  .btn-prev {
    left: 12px;
  }
  .btn-next {
    right: 12px;
  }

  /* ── Counter ── */
  .counter {
    position: absolute;
    bottom: 10px;
    right: 12px;
    background: rgba(0, 0, 0, 0.5);
    color: white;
    font-size: 12px;
    padding: 2px 8px;
    border-radius: 20px;
    z-index: 2;
  }

  /* ── Dots ── */
  .dots {
    display: flex;
    justify-content: center;
    gap: 6px;
    margin-top: 10px;
  }
  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #ccc;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background 0.2s;
  }
  .dot.active {
    background: #333;
  }

  /* ── Thumbnails ── */
  .thumbnails {
    display: flex;
    gap: 8px;
    margin-top: 10px;
    justify-content: center;
    margin-bottom: 20px;
  }

  .thumb {
    border: 2px solid transparent;
    border-radius: 8px;
    cursor: pointer;
    overflow: hidden;
    padding: 0;
    background: none;
    transition: border-color 0.2s;
  }

  /* Horizontal : miniatures 16/9 */
  .is-horizontal .thumb {
    flex: 1;
    aspect-ratio: 16 / 9;
  }

  /* Vertical : petites miniatures portrait */
  .is-vertical .thumb {
    width: 96px;
    aspect-ratio: 9 / 16;
  }

  .thumb.active {
    border-color: #333;
  }
  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
</style>

<script>
  document.querySelectorAll(".carousel-wrap").forEach((wrap) => {
    const track = wrap.querySelector(".carousel-track") as HTMLElement;
    const slides = track.querySelectorAll(".carousel-slide");
    const n = slides.length;
    let cur = 0;

    function go(i: number) {
      cur = ((i % n) + n) % n;
      track.style.transform = `translateX(-${cur * 100}%)`;
      wrap.querySelector(".counter")!.textContent = `${cur + 1} / ${n}`;
      wrap
        .querySelectorAll(".dot")
        .forEach((d, idx) => d.classList.toggle("active", idx === cur));
      wrap
        .querySelectorAll(".thumb")
        .forEach((t, idx) => t.classList.toggle("active", idx === cur));
    }

    (wrap.querySelector("#prev") as HTMLElement).onclick = () => go(cur - 1);
    (wrap.querySelector("#next") as HTMLElement).onclick = () => go(cur + 1);
    wrap.querySelectorAll(".dot").forEach((d) => {
      (d as HTMLElement).onclick = () => go(+d.getAttribute("data-index")!);
    });
    wrap.querySelectorAll(".thumb").forEach((t) => {
      (t as HTMLElement).onclick = () => go(+t.getAttribute("data-index")!);
    });
  });
</script>
